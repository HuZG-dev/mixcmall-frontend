/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
  font-size: 14px;
}

/* 通用样式 */
.container {
  padding: 10px;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 10px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  height: 44px;
  line-height: 44px;
  text-align: center;
  border-radius: 8px;
  font-size: 16px;
  margin: 10px 0;
}

.btn-primary {
  background-color: #ff6700;
  color: #fff;
}

.btn-default {
  background-color: #fff;
  color: #333;
  border: 1px solid #e0e0e0;
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 15px;
  margin: 10px 0;
  box-sizing: border-box;
}

/* 商品卡片样式 */
.product-card {
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 10px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.product-info {
  padding: 10px;
}

.product-name {
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 5px;
  line-height: 1.4;
}

.product-price {
  font-size: 16px;
  font-weight: bold;
  color: #ff6700;
  margin-top: 5px;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 40px 0;
  color: #999;
}

/* 错误提示 */
.error {
  text-align: center;
  padding: 20px;
  color: #f56c6c;
}

/* 成功提示 */
.success {
  text-align: center;
  padding: 20px;
  color: #67c23a;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px 0;
}