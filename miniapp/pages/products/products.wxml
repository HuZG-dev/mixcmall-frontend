<view class="container">
  <!-- 搜索框 -->
  <view class="search-box">
    <input 
      class="search-input" 
      placeholder="搜索商品" 
      bindinput="onSearchInput"
      value="{{keyword}}"
      bindconfirm="search"
    />
    <view class="search-icon" bindtap="search">🔍</view>
  </view>
  
  <!-- 分类筛选 -->
  <view class="category-filter">
    <view 
      class="filter-item {{activeCategory === 0 ? 'active' : ''}}" 
      bindtap="switchCategory" 
      data-id="0"
    >
      全部
    </view>
    <view 
      wx:for="{{categories}}" 
      wx:key="id"
      class="filter-item {{activeCategory === item.id ? 'active' : ''}}" 
      bindtap="switchCategory" 
      data-id="{{item.id}}"
    >
      {{item.name}}
    </view>
  </view>
  
  <!-- 排序 -->
  <view class="sort-bar">
    <view class="sort-item" bindtap="sortByDefault">
      默认
    </view>
    <view class="sort-item" bindtap="sortByPrice">
      价格 {{sortPrice === 'asc' ? '↑' : '↓'}}
    </view>
    <view class="sort-item" bindtap="sortBySales">
      销量 {{sortSales ? '↑' : ''}}
    </view>
  </view>
  
  <!-- 商品列表 -->
  <view class="product-list">
    <view 
      class="product-card" 
        wx:for="{{products}}" 
        wx:key="id"
      bindtap="goToProductDetail" 
      data-id="{{item.id}}"
    >
      <image src="{{item.image}}" class="product-image" mode="aspectFill"></image>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-price">¥{{item.price}}</text>
        <text class="product-sales">销量: {{item.sales}}</text>
      </view>
    </view>
  </view>
  
  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
    <text>{{loading ? '加载中...' : '点击加载更多'}}</text>
  </view>
  
  <!-- 无数据提示 -->
  <view class="empty" wx:if="{{products.length === 0 && !loading}}">
    <text>暂无商品</text>
  </view>
</view>