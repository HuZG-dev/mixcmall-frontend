/* 商品列表页样式 */

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 15rpx 20rpx;
  margin-bottom: 15rpx;
  border-radius: 8px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.search-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 15rpx 20rpx;
  font-size: 26rpx;
  color: #333;
}

.search-icon {
  margin-left: 20rpx;
  font-size: 30rpx;
  color: #999;
}

/* 分类筛选 */
.category-filter {
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  overflow-x: auto;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 50rpx;
  display: inline-block;
}

.filter-item.active {
  color: #ff6700;
  border-bottom: 3rpx solid #ff6700;
  font-weight: 500;
}

/* 排序 */
.sort-bar {
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 15rpx;
}

.sort-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.sort-item:active {
  color: #ff6700;
}

/* 商品列表 */
.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 5rpx;
}

.product-card {
  width: 48%;
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  width: 100%;
  height: 250rpx;
  object-fit: cover;
}

.product-info {
  padding: 15rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6700;
  margin-bottom: 5rpx;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
  background-color: #fff;
  margin: 15rpx 0;
  border-radius: 8px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 无数据提示 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #999;
  background-color: #fff;
  margin: 15rpx 0;
  border-radius: 8px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}