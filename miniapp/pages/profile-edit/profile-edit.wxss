.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.input {
  font-size: 28rpx;
  color: #666;
  border: 1rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
}

.input:disabled {
  background-color: #f5f5f5;
  color: #999;
}

.avatar-upload {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid #ff6700;
}

.upload-btn {
  margin-left: 20rpx;
}

.radio-group {
  display: flex;
  flex-direction: row;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.radio-item text {
  margin-left: 10rpx;
}

.picker {
  border: 1rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  font-size: 28rpx;
  color: #666;
}

.picker-content {
  font-size: 28rpx;
  color: #666;
}

.submit-btn {
  background-color: #ff6700;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.submit-btn:disabled {
  background-color: #ffb380;
}