<view class="container">
  <view class="register-form">
    <view class="form-title">注册</view>
    
    <view class="form-item">
      <input 
        class="input" 
        placeholder="请输入用户名" 
        bindinput="onUsernameInput"
        value="{{username}}"
      />
    </view>
    
    <view class="form-item">
      <input 
        class="input" 
        placeholder="请输入密码" 
        bindinput="onPasswordInput"
        value="{{password}}"
        password
      />
    </view>
    
    <view class="form-item">
      <input 
        class="input" 
        placeholder="请确认密码" 
        bindinput="onConfirmPasswordInput"
        value="{{confirmPassword}}"
        password
      />
    </view>
    
    <button 
      class="btn btn-primary" 
      bindtap="register"
      disabled="{{loading}}"
    >
      {{loading ? '注册中...' : '注册'}}
    </button>
    
    <view class="form-footer">
      <text bindtap="goToLogin">已有账号，去登录</text>
    </view>
  </view>
</view>