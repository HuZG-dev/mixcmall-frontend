<view class="container">
  <view class="login-form">
    <view class="form-title">登录</view>
    
    <view class="form-item">
      <input 
        class="input" 
        placeholder="请输入用户名" 
        bindinput="onUsernameInput"
        value="{{username}}"
      />
    </view>
    
    <view class="form-item">
      <input 
        class="input" 
        placeholder="请输入密码" 
        bindinput="onPasswordInput"
        value="{{password}}"
        password
      />
    </view>
    
    <button 
      class="btn btn-primary" 
      bindtap="login"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登录'}}
    </button>
    
    <view class="form-footer">
      <text bindtap="goToRegister">注册新账号</text>
    </view>
  </view>
</view>