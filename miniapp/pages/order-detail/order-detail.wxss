/* pages/order-detail/order-detail.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.order-detail {
  margin-bottom: 30rpx;
}

.order-status {
  background: linear-gradient(135deg, #ff6700, #ff9500);
  color: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  font-size: 28rpx;
  opacity: 0.9;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 30rpx 0 20rpx;
  border-bottom: 1px solid #eee;
  margin-bottom: 20rpx;
}

.product-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.product-item {
  display: flex;
  gap: 20rpx;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-spec {
  font-size: 24rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.price {
  font-size: 32rpx;
  color: #ff6700;
  font-weight: bold;
}

.quantity {
  font-size: 28rpx;
  color: #999;
}

.address-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.address-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.user-info {
  display: flex;
  gap: 20rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.amount-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #666;
}

.amount-row.freight {
  border-top: 1px solid #f5f5f5;
}

.amount-row.total {
  border-top: 1px solid #f5f5f5;
  margin-top: 10rpx;
  padding-top: 20rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.total-amount {
  color: #ff6700;
  font-size: 40rpx;
}

.action-section {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  position: sticky;
  bottom: 0;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  min-width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid #ddd;
  background-color: #fff;
  color: #666;
  padding: 0 40rpx;
}

.action-btn.primary {
  background-color: #ff6700;
  color: #fff;
  border-color: #ff6700;
}

.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
