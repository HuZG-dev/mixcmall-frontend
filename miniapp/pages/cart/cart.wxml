<view class="container">
  <!-- 购物车商品列表 -->
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
      <view class="item-info">
        <image src="{{item.product.image}}" class="item-image" mode="aspectFill"></image>
        <view class="item-details">
          <text class="item-name">{{item.product.name}}</text>
          <text class="item-price">¥{{item.product.price}}</text>
        </view>
      </view>
      <view class="item-actions">
        <view class="quantity-control">
          <button class="quantity-btn" bindtap="increaseQuantity" data-id="{{item.id}}">+</button>
          <input class="quantity-input" value="{{item.quantity}}" bindinput="onQuantityChange" data-id="{{item.id}}" />
          <button class="quantity-btn" bindtap="decreaseQuantity" data-id="{{item.id}}">-</button>
        </view>
        <button class="delete-btn" bindtap="deleteItem" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>
  
  <!-- 空购物车 -->
  <view class="empty-cart" wx:else>
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <button class="btn-primary" bindtap="goToProducts">去购物</button>
  </view>
  
  <!-- 底部结算栏 -->
  <view class="checkout-bar" wx:if="{{cartItems.length > 0}}">
    <view class="total-price">
      合计: ¥{{totalPrice}}
    </view>
    <button class="checkout-btn" bindtap="checkout">结算</button>
  </view>
</view>