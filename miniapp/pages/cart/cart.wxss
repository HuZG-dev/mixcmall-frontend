/* 购物车页面样式 */

/* 购物车商品列表 */
.cart-list {
  margin-bottom: 100rpx;
}

.cart-item {
  display: flex;
  flex-direction: column;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border-radius: 8px;
}

.item-info {
  display: flex;
  margin-bottom: 20rpx;
}

.item-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8px;
  margin-right: 20rpx;
  object-fit: cover;
}

.item-details {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6700;
}

.item-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  border: 1rpx solid #e0e0e0;
  background-color: #f5f5f5;
  font-size: 32rpx;
}

.quantity-input {
  width: 80rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  border: 1rpx solid #e0e0e0;
  border-left: none;
  border-right: none;
  font-size: 28rpx;
}

.delete-btn {
  color: #f56c6c;
  border: 1rpx solid #f56c6c;
  border-radius: 8rpx;
  padding: 0 30rpx;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 24rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background-color: #fff;
  margin: 15rpx;
  border-radius: 8px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-primary {
  background-color: #ff6700;
  color: #fff;
  border-radius: 8rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

/* 底部结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 15rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6700;
}

.checkout-btn {
  background-color: #ff6700;
  color: #fff;
  border-radius: 8rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}