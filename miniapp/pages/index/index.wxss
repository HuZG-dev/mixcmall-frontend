/* 首页样式 */

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 8px;
  padding: 10rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.search-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  padding: 0 10rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 轮播图 */
.banner {
  margin-bottom: 30rpx;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.swiper {
  width: 100%;
  height: 400rpx;
}

.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.banner-content {
  text-align: center;
  color: #fff;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
  position: relative;
  z-index: 2;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.banner-subtitle {
  font-size: 24rpx;
  margin-bottom: 30rpx;
  display: block;
}

.banner-btn {
  background-color: #ff6700;
  color: #fff;
  padding: 15rpx 40rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  display: inline-block;
}

/* 分类导航 */
.categories {
  margin-bottom: 30rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  position: relative;
  padding-left: 15rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 24rpx;
  background: #ff6700;
  border-radius: 2rpx;
}

.more-link {
  font-size: 24rpx;
  color: #999;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 15rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 23%;
  padding: 15rpx 0;
  border-radius: 8rpx;
  transition: all 0.3s;
  background: #f5f5f5;
}

.category-item:active {
  background: #fff5f0;
}

/* Element UI 图标转义映射 - 将 element 图标类名转换为实际显示的图标 */
.category-icon-element {
  font-size: 48rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
}

/* iconfont 字体图标样式 */
.category-icon-font {
  font-size: 48rpx;
  color: #666;
  margin-bottom: 10rpx;
  transition: color 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.category-item:active .category-icon-font {
  color: #ff6700;
}

.category-icon-emoji {
  font-size: 48rpx;
  color: #666;
  margin-bottom: 10rpx;
  transition: color 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
}

.category-icon-img {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 8rpx;
  transition: transform 0.3s;
}

.category-item:active .category-icon-emoji {
  color: #ff6700;
}

.category-item:active .category-icon-img {
  transform: scale(1.1);
}

.category-name {
  font-size: 22rpx;
  color: #333;
  text-align: center;
}

/* 商品区域 */
.hot-products,
.recommend-products {
  margin-bottom: 30rpx;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 10rpx;
}

.product-card {
  background: #fff;
  border-radius: 8rpx;
  overflow: hidden;
  transition: all 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.product-card:active {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-5rpx);
}

.product-image {
  width: 100%;
  height: 250rpx;
  object-fit: cover;
}

.product-info {
  padding: 15rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-price-wrap {
  display: flex;
  align-items: baseline;
  margin-bottom: 5rpx;
}

.product-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #f56c6c;
}

.product-original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .product-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  
  .category-item {
    width: calc(25% - 15rpx);
  }
}

@media (max-width: 750rpx) {
  .product-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .category-item {
    width: calc(25% - 15rpx);
  }
}