/* 订单列表页样式 */

/* 订单状态筛选 */
.status-filter {
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  overflow-x: auto;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 50rpx;
  display: inline-block;
}

.filter-item.active {
  color: #ff6700;
  border-bottom: 3rpx solid #ff6700;
  font-weight: 500;
}

/* 订单列表 */
.order-list {
  padding: 15rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12px;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 24rpx;
  color: #666;
}

.order-status {
  font-size: 24rpx;
  color: #ff6700;
  font-weight: 500;
}

.order-products {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-item {
  display: flex;
  margin-bottom: 15rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8px;
  margin-right: 15rpx;
  object-fit: cover;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-price-quantity {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 26rpx;
  color: #333;
}

.product-quantity {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
}

.order-total {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-actions {
  display: flex;
  gap: 10rpx;
}

.action-btn {
  padding: 0 30rpx;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  color: #666;
}

.action-btn.primary {
  background-color: #ff6700;
  color: #fff;
  border-color: #ff6700;
}

/* 无订单提示 */
.empty-orders {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background-color: #fff;
  margin: 15rpx;
  border-radius: 8px;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-primary {
  background-color: #ff6700;
  color: #fff;
  border-radius: 8rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}